{
	"compilerOptions": {
		"target": "ES2022",
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"strict": true,
		"verbatimModuleSyntax": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"types": ["node"]
	}
}
