{
	"name": "honeydeck-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/honeydeck",
		"packages/docs",
		"packages/showcase",
		"packages/welcome-deck"
	],
	"packageManager": "pnpm@10.34.4",
	"engines": {
		"node": ">=22.18.0"
	},
	"scripts": {
		"build": "pnpm --recursive --if-present run build",
		"deps:update": "pnpm update --recursive",
		"dev": "pnpm --filter @honeydeck/showcase run dev & pnpm --filter @honeydeck/docs run dev & wait",
		"format": "biome check --write .",
		"lint": "biome check .",
		"pack:dry-run": "pnpm --recursive --if-present run pack:dry-run",
		"pack:smoke": "pnpm --filter @honeydeck/honeydeck run pack:smoke",
		"release:plan": "node ./packages/honeydeck/scripts/release-plan.mjs",
		"test": "pnpm --recursive --if-present test",
		"typecheck": "pnpm --recursive --if-present run typecheck"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15"
	}
}
