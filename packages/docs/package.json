{
	"name": "@honeydeck/docs",
	"private": true,
	"type": "module",
	"scripts": {
		"predev": "npm run docs:sync && npm run search:index",
		"dev": "next dev",
		"start": "next start",
		"prebuild": "npm run docs:sync && npm run search:index",
		"build": "next build",
		"docs:sync": "node ./scripts/sync-docs.mjs",
		"search:index": "node ./scripts/build-search-index.mjs",
		"pretypecheck": "npm run docs:sync && npm run search:index",
		"typecheck": "fumadocs-mdx && next typegen && tsc --noEmit",
		"lint": "biome check .",
		"format": "biome check --write .",
		"test": "node --test \"scripts/**/*.test.mjs\""
	},
	"dependencies": {
		"@honeydeck/honeydeck": "file:../honeydeck",
		"@orama/orama": "^3.1.17",
		"fumadocs-core": "^16.10.5",
		"fumadocs-mdx": "^15.0.12",
		"fumadocs-ui": "^16.10.5",
		"gray-matter": "^4.0.3",
		"lucide-react": "1.17.0",
		"next": "16.2.9",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"remark-gfm": "^4.0.1",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "4.3.0",
		"@types/mdx": "2.0.14",
		"@types/node": "25.9.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"postcss": "8.5.15",
		"tailwindcss": "4.3.0",
		"typescript": "^6.0.3"
	}
}
