{
	"name": "@honeydeck/honeydeck",
	"version": "0.11.2",
	"description": "Compatibility facade for Honeydeck runtime and CLI.",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/honeydeck/honeydeck.git"
	},
	"homepage": "https://honeydeck.dev",
	"bugs": {
		"url": "https://github.com/honeydeck/honeydeck/issues"
	},
	"keywords": [
		"presentations",
		"slides",
		"mdx",
		"react",
		"vite",
		"tailwindcss"
	],
	"type": "module",
	"bin": {
		"honeydeck": "src/cli/bin.js"
	},
	"engines": {
		"node": ">=22.18.0"
	},
	"files": [
		"src",
		"skills",
		"docs",
		"Readme.md",
		"SPEC.md",
		"DEVELOPMENT.md",
		"AGENTS.md"
	],
	"exports": {
		".": "./src/runtime-compat.ts",
		"./app-shell": "./src/app-shell-compat.ts",
		"./types": "./src/types-compat.ts",
		"./layouts": "./src/layouts-compat.ts",
		"./layouts/ColorModeImage": "./src/layouts/ColorModeImage.tsx",
		"./layouts/Blank": "./src/layouts/Blank.tsx",
		"./layouts/Default": "./src/layouts/Default.tsx",
		"./layouts/Cover": "./src/layouts/Cover.tsx",
		"./layouts/Section": "./src/layouts/Section.tsx",
		"./layouts/TwoCol": "./src/layouts/TwoCol.tsx",
		"./layouts/Image": "./src/layouts/Image.tsx",
		"./layouts/ImageLeft": "./src/layouts/ImageLeft.tsx",
		"./layouts/ImageRight": "./src/layouts/ImageRight.tsx",
		"./layouts/placeholders": "./src/layouts/placeholders.ts",
		"./layouts/bee": "./src/layouts/bee/index.ts",
		"./layouts/bee/Blank": "./src/layouts/bee/Blank.tsx",
		"./layouts/bee/Default": "./src/layouts/bee/Default.tsx",
		"./layouts/bee/Cover": "./src/layouts/bee/Cover.tsx",
		"./layouts/bee/Section": "./src/layouts/bee/Section.tsx",
		"./layouts/bee/TwoCol": "./src/layouts/bee/TwoCol.tsx",
		"./layouts/bee/Image": "./src/layouts/bee/Image.tsx",
		"./layouts/bee/ImageLeft": "./src/layouts/bee/ImageLeft.tsx",
		"./layouts/bee/ImageRight": "./src/layouts/bee/ImageRight.tsx",
		"./layouts/clean": "./src/layouts/clean/index.ts",
		"./layouts/clean/Blank": "./src/layouts/clean/Blank.tsx",
		"./layouts/clean/Default": "./src/layouts/clean/Default.tsx",
		"./layouts/clean/Cover": "./src/layouts/clean/Cover.tsx",
		"./layouts/clean/Section": "./src/layouts/clean/Section.tsx",
		"./layouts/clean/TwoCol": "./src/layouts/clean/TwoCol.tsx",
		"./layouts/clean/Image": "./src/layouts/clean/Image.tsx",
		"./layouts/clean/ImageLeft": "./src/layouts/clean/ImageLeft.tsx",
		"./layouts/clean/ImageRight": "./src/layouts/clean/ImageRight.tsx",
		"./theme.css": "./src/theme.css",
		"./themes/base.css": "./src/themes/base.css",
		"./themes/clean.css": "./src/themes/clean.css",
		"./themes/bee.css": "./src/themes/bee.css",
		"./components": "./src/components-compat.ts",
		"./components/code-block": "./src/components/code-block.ts",
		"./components/code-block/normal": "./src/components/code-block-normal.ts",
		"./components/code-block/magic": "./src/components/code-block-magic.ts",
		"./remark/shiki-code-blocks": "./src/remark/shiki-code-blocks.ts",
		"./vite-plugin": "./src/vite-plugin.ts"
	},
	"scripts": {
		"format": "biome check --write",
		"lint": "biome check",
		"prepack": "npm -w @honeydeck/docs run export:package-docs",
		"pack:dry-run": "npm pack --dry-run",
		"pack:smoke": "node ./scripts/packed-smoke.mjs",
		"release:plan": "node ./scripts/release-plan.mjs",
		"test": "node --test --import tsx \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@honeydeck/runtime": "0.11.2",
		"@honeydeck/cli": "0.11.2"
	},
	"peerDependencies": {
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"tailwindcss": "^4.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "^25.6.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	}
}
