{
	"name": "@honeydeck/welcome-deck",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "node --import tsx ../honeydeck/src/cli/index.ts build --deck deck.mdx",
		"dev": "node --import tsx ../honeydeck/src/cli/index.ts dev --deck deck.mdx",
		"pdf": "node --import tsx ../honeydeck/src/cli/index.ts pdf --deck deck.mdx -o welcome.pdf",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@honeydeck/honeydeck": "workspace:*",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.23.0",
		"ogl": "^1.0.11",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"shadcn": "^4.12.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.2",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.3"
	},
	"imports": {
		"#components/*": "./src/components/*.tsx",
		"#lib/*": "./src/lib/*.ts",
		"#hooks/*": "./src/hooks/*.ts"
	}
}
